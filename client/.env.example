# Copy this file to .env and fill in real values. Never commit the real .env.
# All Vite-exposed variables MUST be prefixed with VITE_.

VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
VITE_FIREBASE_APP_ID=your-firebase-app-id

# Backend API base URL
# For local development: http://localhost:5000/api
# For production: https://your-deployed-server-url.com/api
# IMPORTANT: Update this to your deployed server URL for mobile to work
VITE_API_BASE_URL=http://localhost:5000/api
