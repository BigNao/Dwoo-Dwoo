rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isCitizen() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'citizen';
    }

    // reports: anyone can create (anonymous or registered citizen reporting).
    // Reads are restricted — the backend's track-by-reference and admin
    // list endpoints use the Admin SDK, which bypasses these rules.
    // The client only reads directly for the live map and "My Reports",
    // both of which require an authenticated session.
    match /reports/{reportId} {
      allow create: if true;
      allow read: if isAdmin() || (isSignedIn() && resource.data.user_id == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    // users: each citizen manages their own profile document; only an
    // admin (or the backend, via the Admin SDK) may change roles.
    // CRITICAL: Role can never be changed via client SDK - only Admin SDK
    match /users/{userId} {
      // Users can only create their own document
      allow create: if isSignedIn() && request.auth.uid == userId &&
        request.resource.data.role == 'citizen'; // Force role to citizen on create
      
      // Users can read their own profile (needed for auth context)
      allow read: if isSignedIn() && request.auth.uid == userId;
      
      // Users can update their own profile but CANNOT change role
      allow update: if isSignedIn() && request.auth.uid == userId &&
        request.resource.data.role == resource.data.role; // Role must remain unchanged
      
      // No deletes via client SDK
      allow delete: if false;
    }

    // admin_logs: written only via the backend (Admin SDK), readable by admins.
    match /admin_logs/{logId} {
      allow read: if isAdmin();
      allow write: if false;
    }
  }
}
