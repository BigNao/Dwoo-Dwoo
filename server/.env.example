# Copy this file to .env and fill in real values. Never commit the real .env.

PORT=5000

# Firebase Storage bucket (used to init firebase-admin's storage client)
FIREBASE_STORAGE_BUCKET=your-project.appspot.com

# Full Firebase service account JSON, as a single-line string.
# Firebase Console -> Project Settings -> Service Accounts -> Generate new private key
FIREBASE_ADMIN_SDK_KEY={"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"..."}

# Cloudinary configuration for image uploads
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
